#. FragrantFlowers.STRINGS.PLANTS.DUSKLAVENDER.DESC
msgctxt "FragrantFlowers.STRINGS.PLANTS.DUSKLAVENDER.DESC"
msgid "A shrub-like plant blooms with a beautiful <link=\"DUSKBLOOM\">Duskbloom</link>."
msgstr "Кустарниковое растение, которое цветет красивыми <link=\"DUSKBLOOM\">цветами сумеречной лаванды</link>."

#. FragrantFlowers.STRINGS.PLANTS.DUSKLAVENDER.DOMESTICATED_DESC
msgctxt "FragrantFlowers.STRINGS.PLANTS.DUSKLAVENDER.DOMESTICATED_DESC"
msgid "/nIn domesticated environment this crop requires the use of <link=\"PHOSPHORITE\">Phosphorite</link> as fertilization."
msgstr "Кустарниковое растение, которое цветет красивыми <link=\"DUSKBLOOM\">цветами сумеречной лаванды</link>.""

#. FragrantFlowers.STRINGS.PLANTS.DUSKLAVENDER.NAME
msgctxt "FragrantFlowers.STRINGS.PLANTS.DUSKLAVENDER.NAME"
msgid "<link=\"DUSKBLOOMLAVENDER\">Duskbloom Lavender</link>"
msgstr "<link=\"DUSKBLOOMLAVENDER\">Сумеречная лаванда</link>"

#. FragrantFlowers.STRINGS.PLANTS.RIMEDMALLOW.DESC
msgctxt "FragrantFlowers.STRINGS.PLANTS.RIMEDMALLOW.DESC"
msgid "An evergreen plant well adapt to thrive in very cold environments. Produces a fluffy <link=\"RIMEDCOTTON\">Rimed Cotton Boll</link>."
msgstr "Вечнозеленое растение, хорошо приспособленное к очень холодным условиям. Производит пушистую <link=\"RIMEDCOTTON\">коробочку ледохлопка</link>."

#. FragrantFlowers.STRINGS.PLANTS.RIMEDMALLOW.DOMESTICATED_DESC
msgctxt "FragrantFlowers.STRINGS.PLANTS.RIMEDMALLOW.DOMESTICATED_DESC"
msgid "/nIn domesticated environment this crop requires the use of pure water <link=\"ICE\">Ice</link> as fertilization."
msgstr "Вечнозеленое растение, хорошо приспособленное к очень холодным условиям. Производит пушистую <link=\"RIMEDCOTTON\">коробочку ледохлопка</link>."

#. FragrantFlowers.STRINGS.PLANTS.RIMEDMALLOW.NAME
msgctxt "FragrantFlowers.STRINGS.PLANTS.RIMEDMALLOW.NAME"
msgid "<link=\"RIMEDMALLOWPLANT\">Rimed Mallow</link>"
msgstr "<link=\"RIMEDMALLOWPLANT\">Ледяная мальва</link>"

#. FragrantFlowers.STRINGS.PLANTS.SPINOSA.DESC
msgctxt "FragrantFlowers.STRINGS.PLANTS.SPINOSA.DESC"
msgid "A rather thorny sten plant that blooms with a beautiful <link=\"SPINOSAROSE\">Spinosa Rose</link>."
msgstr "Довольно колючее растение, на котором цветут красивые <link=\"SPINOSAROSE\">розы шиповника</link>."

#. FragrantFlowers.STRINGS.PLANTS.SPINOSA.DOMESTICATED_DESC
msgctxt "FragrantFlowers.STRINGS.PLANTS.SPINOSA.DOMESTICATED_DESC"
msgid "A rather thorny sten plant that blooms with a beautiful <link=\"SPINOSAROSE\">Spinosa Rose</link>./nIn domesticated environment this crop requires copious amounts of<link=\"WATER\">Water</link>, and<link=\"DIRT\">Dirt</link>as fertilizer. Also requires direct exposure to sunlight."
msgstr "Довольно колючее растение, на котором цветут красивые <link=\"SPINOSAROSE\">розы шиповника</link>."

#. FragrantFlowers.STRINGS.PLANTS.SPINOSA.NAME
msgctxt "FragrantFlowers.STRINGS.PLANTS.SPINOSA.NAME"
msgid "<link=\"SPINOSAPLANT\">Blooming Spinosa</link>"
msgstr "<link=\"SPINOSAPLANT\">Цветущий шиповник</link>"

#. FragrantFlowers.STRINGS.PLANTS.SUPERDUSKLAVENDER.DESC
msgctxt "FragrantFlowers.STRINGS.PLANTS.SUPERDUSKLAVENDER.DESC"
msgid "A shrub-like plant sprouts with an edible <link=\"DUSKBERRY\">Duskberry</link>."
msgstr "Кустарниковое растение, которое плодоносит съедобной <link=\"DUSKBERRY\">сумеряникой</link>."

#. FragrantFlowers.STRINGS.PLANTS.SUPERDUSKLAVENDER.DOMESTICATED_DESC
